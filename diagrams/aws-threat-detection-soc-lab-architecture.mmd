flowchart LR
  %% AWS Threat Detection SOC Lab architecture, matching current Terraform after AWS Config removal.

  subgraph aws["AWS Cloud"]
    attacker["soc-lab-stratus\nAttacker / IAM user"]
    cloudtrail["CloudTrail\nAPI activity logs"]
    target["Optional EC2 Stratus Target"]
    vpcflow["VPC Flow Logs\nDefault VPC traffic"]
    ctBucket["S3 Bucket\nsoc-lab-cloudtrail-*"]
    vfBucket["S3 Bucket\nsoc-lab-vpcflow-*"]
    ctQueue["SQS Queue\ncloudtrail-s3-events"]
    vfQueue["SQS Queue\nvpcflow-s3-events"]
    splunkIam["IAM user\nsoc-lab-splunk-addon"]
  end

  subgraph local["Docker Desktop / Local"]
    splunk["Splunk Server\nAWS Add-on"]
    search["Search & Reporting"]
    dashboard["Dashboard"]
  end

  attacker -->|Perform AWS API actions| cloudtrail
  attacker -->|Act on target resources| target
  target -->|Generates network traffic| vpcflow

  cloudtrail -->|Writes logs| ctBucket
  vpcflow -->|Writes logs| vfBucket
  ctBucket -->|New object notification| ctQueue
  vfBucket -->|New object notification| vfQueue

  splunkIam -->|Read logs to ingest to Splunk| ctQueue
  splunkIam -->|Read logs to ingest to Splunk| vfQueue
  splunk -->|Poll logs from specified S3 buckets| splunkIam

  splunk --> search
  search --> dashboard
